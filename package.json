{
  "name": "sudoku",
  "version": "1.0.0",
  "description": "一款基于 HTML5 的多模式数独游戏，支持经典数独、杀手数独、拼图数独、迷你数独、巨无霸数独和环状数独。",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.sudoku.master",
    "productName": "SudokuMaster",
    "directories": {
      "output": "dist"
    },
    "files": [
      "www/**/*",
      "main.js"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
